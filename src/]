#include "utilities.h"

#include <stdbool.h>
#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <sys/types.h>

typedef enum Mode{
    SEQUENTIAL,
    PARALLEL,
}Mode;

Mode mode = SEQUENTIAL;

char **CheckIsInputRedirection(char *command);
char **CheckIsOutputRedirection(char *command,bool *isAppend);
char **CheckIsPipeCommand(char *command);
void ExecutePipeline(char **pipeCommands);
bool TryPipelineExecution(char *command);

void GetInput(char **str,size_t *size){
	mode == SEQUENTIAL ? printf("seq > ") : printf("par >");
	getline(str,size,stdin);
	printf("\n");
};

char **SliceInput(char *input){
	char **inputs = SliceStr(input,";\n");

	return inputs;
};

bool Execute(char *command){
	int originalStdout = -1;
	int originalStdin = -1;
	int isAppend;
	char **redirectionCommand;
	char **inputRedirectionCommand;
	char **pipeCommands;

	if((redirectionCommand = CheckIsRedirection(command,&isAppend)) != NULL){
		Trim(redirectionCommand[1]);
		originalStdout = ChangeStdout(redirectionCommand[1],isAppend);
		
		free(redirectionCommand);
	};

	if((inputRedirectionCommand = CheckIsInputRedirection(command)) != NULL){
		Trim(inputRedirectionCommand[1]);
		originalStdin = ChangeStdin(inputRedirectionCommand[1]);

		free(inputRedirectionCommand);
	};

	if(TryPipelineExecution(command)){
		return true;
	};

	if((pipeCommands = CheckIsPipeCommand(command)) != NULL){
		ExecutePipeline(pipeCommands);

		free(pipeCommands);
	}else{
		FinalExecute(command);
	};

	if(originalStdout != -1){
        	RestoreStdout(originalStdout);
		originalStdout = -1;
	};

	if(originalStdin != -1){
		RestoreStdin(originalStdin);
		originalStdin = -1;
	};

	return  1;
};

bool TryRedirection(char *command){
	bool isAppend;
	char **redirection;

	if((redirection = CheckIsInputRedirection(command)) != NULL){
		Trim(redirection[1]);
		ChangeStdin(redirection[1]);


		free(redirection);
	};
	
	if((redirection = CheckIsOutputRedirection(command,&isAppend)) != NULL){
		Trim(redirection[1]);
		int flags = O_CREAT | O_WRONLY;
		flags |= isAppend ? O_APPEND : O_TRUNC;

		ChangeStdout(redirection[1],flags);
		free(redirection);
	};



};


bool TryPipelineExecution(char *command){
	char **pipeCommands;

	if((pipeCommands = CheckIsPipeCommand(command)) == NULL){
		return false;
	};

	ExecutePipeline(pipeCommands);
	free(pipeCommands);
	return true;
};
